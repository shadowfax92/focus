<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Reference template. `focus install` resolves the paths for the current user. -->
<plist version="1.0">
<dict>
  <key>Label</key><string>com.focus.daemon</string>
  <key>ProgramArguments</key>
  <array><string>__FOCUS_APP_BINARY__</string><string>daemon</string></array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>ProcessType</key><string>Interactive</string>
  <key>StandardOutPath</key><string>__FOCUS_LOG__</string>
  <key>StandardErrorPath</key><string>__FOCUS_LOG__</string>
</dict>
</plist>
